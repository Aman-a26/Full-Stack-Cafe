<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inventory Manager | Cafe Delight</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #fafaf9; }
        .font-serif { font-family: 'Playfair Display', serif; }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-6">

    <div class="bg-white rounded-[3rem] shadow-2xl p-10 md:p-14 w-full max-w-2xl border border-stone-100">
        <div class="flex justify-between items-start mb-12">
            <div>
                <h1 class="font-serif text-4xl mb-2">New <span class="italic text-amber-600">Delight</span></h1>
                <p class="text-stone-400 text-sm">Add a new item to the artisanal menu</p>
            </div>
            <a href="/admin-dashboard" class="text-stone-300 hover:text-stone-900 transition-colors"><svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></a>
        </div>
        
        <form action="/add-product" method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-2 gap-8">
            
            <div class="md:col-span-2">
                <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-stone-400 mb-2 ml-1">Product Name</label>
                <input type="text" name="name" required placeholder="e.g. Signature Cold Brew"
                       class="w-full bg-stone-50 border-none rounded-2xl px-6 py-4 focus:ring-2 focus:ring-amber-500 transition-all placeholder:text-stone-300">
            </div>

            <div>
                <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-stone-400 mb-2 ml-1">Category</label>
                <select name="category" 
                        class="w-full bg-stone-50 border-none rounded-2xl px-6 py-4 focus:ring-2 focus:ring-amber-500 transition-all appearance-none cursor-pointer">
                    <option value="Coffee">Coffee</option>
                    <option value="Snacks">Snacks</option>
                    <option value="Desserts">Desserts</option>
                    <option value="Beverages">Beverages</option>
                </select>
            </div>
            
            <div>
                <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-stone-400 mb-2 ml-1">Price (₹)</label>
                <input type="number" name="price" step="0.01" required placeholder="0.00"
                       class="w-full bg-stone-50 border-none rounded-2xl px-6 py-4 focus:ring-2 focus:ring-amber-500 transition-all placeholder:text-stone-300">
            </div>

            <div>
                <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-stone-400 mb-2 ml-1">Initial Stock</label>
                <input type="number" name="stock" required min="0" placeholder="e.g. 50"
                       class="w-full bg-stone-50 border-none rounded-2xl px-6 py-4 focus:ring-2 focus:ring-amber-500 transition-all placeholder:text-stone-300">
            </div>

            <div class="md:col-span-2">
                <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-stone-400 mb-2 ml-1">Description</label>
                <textarea name="description" rows="3" required placeholder="Describe the experience..."
                          class="w-full bg-stone-50 border-none rounded-2xl px-6 py-4 focus:ring-2 focus:ring-amber-500 transition-all placeholder:text-stone-300 resize-none"></textarea>
            </div>

            <div class="md:col-span-2">
                <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-stone-400 mb-2 ml-1">Product Visual</label>
                <div class="mt-1 flex justify-center px-6 pt-8 pb-10 border-2 border-stone-200 border-dashed rounded-[2rem] hover:border-amber-400 transition bg-stone-50/50">
                    <div class="space-y-1 text-center">
                        <svg class="mx-auto h-12 w-12 text-stone-300" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                            <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <div class="flex text-sm text-gray-600">
                            <label for="file-upload" class="relative cursor-pointer bg-white rounded-full px-4 py-1 shadow-sm font-bold text-amber-600 hover:text-amber-500 transition-colors">
                                <span>Upload Image</span>
                                <input id="file-upload" name="image" type="file" class="sr-only" accept="image/*" required onchange="previewImage(event)">
                            </label>
                        </div>
                    </div>
                </div>
                <img id="output" class="mt-6 hidden w-full h-40 object-cover rounded-[2rem] border border-stone-200 shadow-inner">
            </div>

            <button type="submit" class="md:col-span-2 bg-stone-900 text-white py-5 rounded-[2rem] font-bold text-lg hover:bg-amber-800 transition-all shadow-xl shadow-stone-900/20 active:scale-95">
                Finalize & Add to Menu
            </button>
        </form>
    </div>

    <script>
        function previewImage(event) {
            var reader = new FileReader();
            reader.onload = function(){
                var output = document.getElementById('output');
                output.src = reader.result;
                output.classList.remove('hidden');
            };
            reader.readAsDataURL(event.target.files[0]);
        }
    </script>
</body>
</html>