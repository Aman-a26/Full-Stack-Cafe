<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product - Cafe Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 font-sans flex justify-center items-center min-h-screen p-4">

    <div class="bg-white p-8 md:p-10 rounded-2xl shadow-xl w-full max-w-[550px] my-10">
        <h2 class="text-2xl font-bold mb-6 text-gray-800 border-b-4 border-orange-500 pb-2 inline-block">Add New Product</h2>
        
        <form action="/add-product" method="POST" enctype="multipart/form-data" class="space-y-5">
            
            <div>
                <label class="block mb-1 text-gray-600 font-bold text-sm">Product Name</label>
                <input type="text" name="name" required placeholder="e.g. Classic Burger"
                       class="w-full p-3 border border-gray-300 rounded-xl outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500/10 transition-all">
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block mb-1 text-gray-600 font-bold text-sm">Category</label>
                    <select name="category" 
                            class="w-full p-3 border border-gray-300 rounded-xl outline-none focus:border-orange-500 bg-white">
                        <option value="Coffee">Coffee</option>
                        <option value="Snacks">Snacks</option>
                        <option value="Desserts">Desserts</option>
                        <option value="Beverages">Beverages</option>
                    </select>
                </div>
                <div>
                    <label class="block mb-1 text-gray-600 font-bold text-sm">Price (₹)</label>
                    <input type="number" name="price" step="0.01" required placeholder="0.00"
                           class="w-full p-3 border border-gray-300 rounded-xl outline-none focus:border-orange-500">
                </div>
            </div>

            <div>
                <label class="block mb-1 text-gray-600 font-bold text-sm">Initial Stock Quantity</label>
                <input type="number" name="stock" required min="0" placeholder="e.g. 50"
                       class="w-full p-3 border border-gray-300 rounded-xl outline-none focus:border-orange-500">
                <p class="text-[10px] text-gray-400 mt-1 uppercase tracking-wider">Set to 0 to show "Out of Stock" immediately.</p>
            </div>

            <div>
                <label class="block mb-1 text-gray-600 font-bold text-sm">Description</label>
                <textarea name="description" rows="2" required placeholder="Describe the taste, ingredients, etc..."
                          class="w-full p-3 border border-gray-300 rounded-xl outline-none focus:border-orange-500"></textarea>
            </div>

            <div>
                <label class="block mb-1 text-gray-600 font-bold text-sm">Product Image</label>
                <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-xl hover:border-orange-400 transition">
                    <div class="space-y-1 text-center">
                        <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                            <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <div class="flex text-sm text-gray-600">
                            <label for="file-upload" class="relative cursor-pointer bg-white rounded-md font-medium text-orange-600 hover:text-orange-500">
                                <span>Upload a file</span>
                                <input id="file-upload" name="image" type="file" class="sr-only" accept="image/*" required onchange="previewImage(event)">
                            </label>
                        </div>
                        <p class="text-xs text-gray-500">PNG, JPG, GIF up to 10MB</p>
                    </div>
                </div>
                <img id="output" class="mt-4 hidden w-full h-32 object-cover rounded-xl border border-gray-200">
            </div>

            <div class="flex gap-3 pt-2">
                <button type="submit" class="flex-[2] bg-orange-500 text-white p-3 rounded-xl font-bold hover:bg-orange-600 transition shadow-lg shadow-orange-100">
                    Add Product
                </button>
                <a href="/admin-dashboard" class="flex-1 bg-gray-100 text-gray-500 text-center p-3 rounded-xl font-bold hover:bg-gray-200 transition">
                    Cancel
                </a>
            </div>
        </form>
    </div>

    <script>
        function previewImage(event) {
            var reader = new FileReader();
            reader.onload = function(){
                var output = document.getElementById('output');
                output.src = reader.result;
                output.classList.remove('hidden');
            };
            reader.readAsDataURL(event.target.files[0]);
        }
    </script>
</body>
</html>