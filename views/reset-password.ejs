<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - Cafe Food</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-[#f093fb] to-[#f5576c] min-h-screen flex justify-center items-center font-sans p-5">

    <div class="bg-white p-10 rounded-xl shadow-2xl w-full max-w-[450px]">
        <div class="text-center mb-8">
            <h1 class="text-[#333] text-3xl font-bold mb-2">Choose a New Password</h1>
        </div>

        <% if (error) { %>
            <div class="bg-red-100 border border-red-200 text-red-800 p-3 rounded-md mb-5 text-sm">
                <%= error %>
            </div>
        <% } %>

        <form method="POST" action="/reset-password/<%= token %>" class="space-y-5">
            <div>
                <label for="password" class="block mb-1 text-gray-800 font-medium">New Password</label>
                <input type="password" id="password" name="password" required placeholder="Enter new password"
                       class="w-full p-3 border border-gray-300 rounded-md text-sm outline-none focus:border-[#f5576c] focus:ring-2 focus:ring-[#f5576c]/20 transition-all">
            </div>

            <div>
                <label for="confirmPassword" class="block mb-1 text-gray-800 font-medium">Confirm New Password</label>
                <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="Re-enter new password"
                       class="w-full p-3 border border-gray-300 rounded-md text-sm outline-none focus:border-[#f5576c] focus:ring-2 focus:ring-[#f5576c]/20 transition-all">
            </div>

            <button type="submit" class="w-full p-3 bg-gradient-to-r from-[#f093fb] to-[#f5576c] text-white rounded-md font-semibold text-lg hover:-translate-y-0.5 transition-transform active:translate-y-0 shadow-md">
                Update Password
            </button>
        </form>
    </div>

</body>
</html>