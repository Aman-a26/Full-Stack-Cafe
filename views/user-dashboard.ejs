<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Dashboard - Cafe Food</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .cart-badge {
            position: absolute;
            top: -8px;
            right: -12px;
            background: white;
            color: #f97316;
            font-size: 0.75rem;
            padding: 2px 6px;
            border-radius: 9999px;
            font-weight: 800;
        }
    </style>
</head>
<body class="bg-gray-50">
    <nav class="bg-orange-500 p-4 text-white flex justify-between items-center shadow-md sticky top-0 z-50">
        <h1 class="text-2xl font-bold tracking-tight">Cafe Dashboard</h1>
        <div class="flex items-center space-x-8">
            <a href="/cart" class="relative hover:text-orange-200 transition font-bold flex items-center gap-1">
                <span>🛒</span> Cart
                <% if (cartCount > 0) { %>
                    <span class="cart-badge shadow-sm"><%= cartCount %></span>
                <% } %>
            </a>

            <% if (user) { %>
                <div class="flex items-center gap-4">
                    <span class="hidden md:inline text-sm font-medium opacity-90">Hi, <%= user.username %></span>
                    <a href="/logout" class="bg-white text-orange-600 px-5 py-1.5 rounded-full font-bold hover:bg-orange-50 transition shadow-sm">
                        Logout
                    </a>
                </div>
            <% } else { %>
                <a href="/login" class="bg-white text-blue-600 px-5 py-1.5 rounded-full font-bold hover:bg-blue-50 transition shadow-sm">
                    Login
                </a>
            <% } %>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto p-6 space-y-12">
        <section>
            <h2 class="text-2xl font-bold mb-6 text-gray-800">Available Menu</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% products.forEach(product => { %>
                    <div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden group border border-gray-100 <%= !product.isActive ? 'grayscale-[0.5] opacity-80' : '' %>">
                        <div class="overflow-hidden relative">
                            <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-48 object-cover group-hover:scale-110 transition duration-500">
                            
                            <% if (!product.isActive) { %>
                                <div class="absolute inset-0 bg-black/10 flex items-center justify-center">
                                    <span class="bg-gray-800 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-tighter">Temporarily Unavailable</span>
                                </div>
                            <% } %>
                        </div>
                        <div class="p-5">
                            <h3 class="font-bold text-lg text-gray-800"><%= product.name %></h3>
                            <p class="text-gray-400 text-sm h-10 overflow-hidden mb-4 mt-1"><%= product.description %></p>
                            <div class="flex justify-between items-center">
                                <span class="text-orange-600 font-black text-xl">₹<%= product.price %></span>
                                
                                <% if (product.isActive && product.stock > 0) { %>
                                    <button onclick="addToCart('<%= product._id %>')" 
                                        class="bg-orange-500 text-white px-4 py-2 rounded-xl font-bold hover:bg-orange-600 active:scale-95 transition shadow-md shadow-orange-100">
                                        Add +
                                    </button>
                                <% } else { %>
                                    <button disabled class="bg-gray-200 text-gray-400 px-4 py-2 rounded-xl font-bold cursor-not-allowed">
                                        Out of Stock
                                    </button>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <% if (pages > 1) { %>
                <div class="mt-12 flex justify-center items-center space-x-3">
                    <% if (current > 1) { %>
                        <a href="/user-dashboard?page=<%= current - 1 %>" class="px-4 py-2 bg-white border border-gray-200 rounded-lg text-gray-600 font-bold hover:bg-orange-50 hover:text-orange-500 transition">← Prev</a>
                    <% } %>

                    <% for (let i = 1; i <= pages; i++) { %>
                        <a href="/user-dashboard?page=<%= i %>" 
                           class="px-4 py-2 rounded-lg font-bold transition <%= current == i ? 'bg-orange-500 text-white shadow-md' : 'bg-white text-gray-600 border border-gray-100 hover:bg-orange-50' %>">
                            <%= i %>
                        </a>
                    <% } %>

                    <% if (current < pages) { %>
                        <a href="/user-dashboard?page=<%= current + 1 %>" class="px-4 py-2 bg-white border border-gray-200 rounded-lg text-gray-600 font-bold hover:bg-orange-50 hover:text-orange-500 transition">Next →</a>
                    <% } %>
                </div>
            <% } %>
        </section>

        <section class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100">
            <h2 class="text-2xl font-bold text-gray-800 mb-8">My Recent Orders</h2>
            
            <div class="space-y-4">
                <% if (user) { %>
                    <% orders.forEach(order => { %>
                        <div class="flex flex-col md:flex-row md:items-center justify-between p-5 border border-gray-100 rounded-2xl hover:border-orange-200 hover:bg-orange-50/30 transition group">
                            <div class="space-y-1">
                                <p class="text-xs font-bold text-gray-300 uppercase tracking-widest">ID: #<%= order._id.toString().slice(-6) %></p>
                                <div class="text-gray-700 font-semibold">
                                    <% order.items.forEach((item, index) => { %>
                                        <%= item.name %><span class="text-gray-400 text-sm"> (x<%= item.quantity %>)</span><%= index < order.items.length - 1 ? ', ' : '' %>
                                    <% }) %>
                                </div>
                            </div>
                            <div class="flex items-center space-x-8 mt-4 md:mt-0">
                                <span class="text-xl font-black text-gray-900">₹<%= order.totalAmount.toFixed(2) %></span>
                                <span class="px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-wider
                                    <%= order.status === 'Pending' ? 'bg-amber-100 text-amber-600' : 'bg-emerald-100 text-emerald-600' %>">
                                    ● <%= order.status %>
                                </span>
                            </div>
                        </div>
                    <% }) %>
                    
                    <% if(orders.length === 0) { %>
                        <div class="text-center py-6 text-gray-400 italic">No orders found yet.</div>
                    <% } %>
                <% } else { %>
                    <div class="py-10 text-center border-2 border-dashed border-gray-100 rounded-2xl">
                        <p class="text-gray-400 font-medium">Want to see your order history?</p>
                        <a href="/login" class="text-orange-500 font-bold hover:underline mt-2 inline-block">Sign in to your account</a>
                    </div>
                <% } %>
            </div>
        </section>
    </main>

    <footer class="py-10 text-center text-gray-300 text-sm">
        &copy; 2026 Cafe Food Canteen System
    </footer>

    <script>
        function addToCart(productId) {
            fetch('/add-to-cart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId: productId })
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    window.location.reload();
                } else {
                    alert(data.message || 'Error adding item.');
                }
            })
            .catch(err => console.error('Error:', err));
        }
    </script>
</body>
</html>