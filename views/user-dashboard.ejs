<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menu | Cafe Delight</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-serif { font-family: 'Playfair Display', serif; }
        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(0,0,0,0.05); }
    </style>
</head>
<body class="bg-stone-50 text-stone-900">
    <!-- Main Navigation -->
    <nav class="sticky top-0 z-50 glass px-6 py-5 flex justify-between items-center">
        <a href="/" class="text-2xl font-serif font-bold text-amber-900 tracking-tight flex items-center gap-2">
            Cafe<span class="text-amber-600">Delight</span>
        </a>

        <div class="flex items-center gap-8">
            <a href="/cart" class="relative group flex items-center gap-2 font-semibold text-stone-600 hover:text-amber-600 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                Cart
                <% if (cartCount > 0) { %>
                    <span class="absolute -top-2 -right-3 bg-amber-600 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full animate-pulse"><%= cartCount %></span>
                <% } %>
            </a>

            <% if (user) { %>
                <div class="flex items-center gap-6">
                    <div class="hidden md:block text-right leading-none">
                        <p class="text-[10px] uppercase font-bold text-stone-400 tracking-widest mb-1">Customer</p>
                        <p class="text-sm font-bold"><%= user.username %></p>
                    </div>
                    <a href="/logout" class="text-stone-400 hover:text-red-500 transition-colors"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg></a>
                </div>
            <% } else { %>
                <a href="/login" class="bg-stone-900 text-white px-6 py-2 rounded-full font-bold text-sm hover:bg-amber-800 transition-all shadow-lg shadow-stone-900/10">Login</a>
            <% } %>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-6 py-12 space-y-32">
        <section class="text-center max-w-2xl mx-auto py-10">
            <span class="text-[10px] font-black uppercase tracking-[0.5em] text-amber-600 mb-4 block">Seasonal Selection</span>
            <h1 class="font-serif text-5xl md:text-7xl text-stone-900 mb-6 tracking-tight leading-none">The <span class="italic text-amber-600">Daily</span> Menu</h1>
            <p class="text-stone-400 text-lg leading-relaxed">Indulge in our curated selection of artisanal coffee and gourmet treats, prepared fresh daily in our kitchen.</p>
        </section>

        <section id="menu">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
                <% products.forEach(product => { %>
                    <div class="bg-white rounded-[3rem] overflow-hidden shadow-2xl shadow-stone-200/40 hover:-translate-y-4 transition-all duration-500 border border-stone-100/50 group">
                        <div class="h-64 overflow-hidden relative">
                            <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                            
                            <% if (!product.isActive) { %>
                                <div class="absolute inset-0 bg-white/40 backdrop-blur-[2px] flex items-center justify-center">
                                    <span class="bg-stone-900 text-white text-[10px] font-black px-4 py-2 rounded-full uppercase tracking-[0.2em]">Unavailable</span>
                                </div>
                            <% } %>
                            <div class="absolute bottom-4 right-4 bg-white/90 backdrop-blur px-4 py-1.5 rounded-full text-lg font-black text-amber-800 border border-white">
                                ₹<%= product.price %>
                            </div>
                        </div>
                        <div class="p-8">
                            <h3 class="font-serif text-2xl text-stone-900 mb-2"><%= product.name %></h3>
                            <p class="text-stone-400 text-sm mb-8 line-clamp-2 leading-relaxed"><%= product.description %></p>
                            
                            <% if (product.isActive && product.stock > 0) { %>
                                <button onclick="addToCart('<%= product._id %>')" 
                                    class="w-full bg-stone-900 text-white py-4 rounded-2xl font-bold hover:bg-amber-800 active:scale-95 transition shadow-xl shadow-stone-900/10">
                                    Add to Order
                                </button>
                            <% } else { %>
                                <button disabled class="w-full bg-stone-100 text-stone-400 py-4 rounded-2xl font-bold cursor-not-allowed">
                                    Sold Out
                                </button>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- Pagination -->
            <% if (pages > 1) { %>
                <div class="mt-16 flex justify-center gap-3">
                    <% for (let i = 1; i <= pages; i++) { %>
                        <a href="/user-dashboard?page=<%= i %>" 
                           class="w-12 h-12 flex items-center justify-center rounded-2xl font-black transition-all <%= current == i ? 'bg-amber-600 text-white shadow-lg' : 'bg-white text-stone-400 hover:bg-stone-100 border border-stone-200' %>">
                            <%= i %>
                        </a>
                    <% } %>
                </div>
            <% } %>
        </section>

        <section class="bg-stone-900 text-white p-10 md:p-16 rounded-[3rem] shadow-2xl relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-amber-600/10 rounded-full -mr-32 -mt-32 blur-3xl"></div>
            <h2 class="font-serif text-3xl mb-12 flex items-center gap-4">
                <span class="w-8 h-px bg-amber-600"></span> Recent Cravings
            </h2>
            
            <div class="space-y-6">
                <% if (user) { %>
                    <% orders.forEach(order => { %>
                        <div class="flex flex-col md:flex-row md:items-center justify-between p-8 border border-white/10 rounded-3xl bg-white/5 backdrop-blur-sm hover:bg-white/10 transition-all group">
                            <div class="space-y-1">
                                <p class="text-[10px] font-black text-amber-600 uppercase tracking-[0.3em] mb-2">Order #<%= order._id.toString().slice(-6) %></p>
                                <div class="text-stone-300 font-medium">
                                    <% order.items.forEach((item, index) => { %>
                                        <%= item.name %><span class="text-stone-500 text-xs italic"> (x<%= item.quantity %>)</span><%= index < order.items.length - 1 ? ', ' : '' %>
                                    <% }) %>
                                </div>
                            </div>
                            <div class="flex items-center gap-10 mt-6 md:mt-0">
                                <span class="text-2xl font-black">₹<%= order.totalAmount.toFixed(2) %></span>
                                <span class="px-5 py-2 rounded-full text-[10px] font-black uppercase tracking-widest
                                    <%= order.status === 'Pending' ? 'bg-amber-600/20 text-amber-600' : 'bg-emerald-600/20 text-emerald-600' %>">
                                    ● <%= order.status %>
                                </span>
                            </div>
                        </div>
                    <% }) %>
                    
                    <% if(orders.length === 0) { %>
                        <div class="text-center py-12 border-2 border-dashed border-white/10 rounded-3xl">
                            <p class="text-stone-500 italic">You haven't ordered any delights yet.</p>
                        </div>
                    <% } %>
                <% } else { %>
                    <div class="py-16 text-center border-2 border-dashed border-white/10 rounded-3xl">
                        <p class="text-stone-400 mb-6">Sign in to view your gourmet order history.</p>
                        <a href="/login" class="inline-block bg-amber-600 text-white px-10 py-4 rounded-2xl font-bold hover:bg-amber-700 transition-all shadow-xl shadow-amber-900/20">Login to Dashboard</a>
                    </div>
                <% } %>
            </div>
        </section>
    </main>

    <footer class="py-20 text-center border-t border-stone-100">
        <p class="text-stone-300 text-xs uppercase tracking-[0.4em] mb-4">&copy; 2026 Cafe Delight Artisanal Food</p>
        <div class="flex justify-center gap-6 text-stone-400">
            <a href="#" class="hover:text-amber-600 transition-colors">Instagram</a>
            <a href="#" class="hover:text-amber-600 transition-colors">Menu</a>
            <a href="#" class="hover:text-amber-600 transition-colors">Contact</a>
        </div>
    </footer>

    <script>
        function addToCart(productId) {
            fetch('/add-to-cart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId: productId })
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    window.location.reload();
                } else {
                    alert(data.message || 'Error adding item.');
                }
            })
            .catch(err => console.error('Error:', err));
        }
    </script>
</body>
</html>