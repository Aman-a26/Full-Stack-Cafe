<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Order Management</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
    <nav class="bg-green-600 p-4 text-white flex justify-between items-center shadow-lg">
        <h1 class="text-xl font-bold">Cafe Admin: Orders</h1>
        <div class="space-x-4">
            <a href="/admin-dashboard" class="hover:underline font-bold">Manage Menu 🍔</a>
            <a href="/logout" class="bg-red-500 px-3 py-1 rounded">Logout</a>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto p-6 space-y-10">
        <section>
            <h2 class="text-2xl font-black text-orange-600 mb-4 flex items-center">
                <span class="mr-2">🔥</span> LIVE ORDERS (Pending/Processing)
            </h2>
            <div class="grid gap-4">
                <% liveOrders.forEach(order => { %>
                    <div class="bg-white p-4 rounded-lg shadow-sm border-l-4 border-orange-500 flex justify-between items-center">
                        <div>
                            <p class="text-xs text-gray-400">Order #<%= order._id.toString().slice(-6) %></p>
                            <h4 class="font-bold text-lg"><%= order.user ? order.user.username : 'Guest' %></h4>
                            <p class="text-sm text-gray-600">
                                <% order.items.forEach(item => { %> <%= item.name %> (x<%= item.quantity %>) <% }) %>
                            </p>
                        </div>
                        <div class="text-right space-y-2">
                            <p class="font-black text-xl">$<%= order.totalAmount %></p>
                            <form action="/admin/update-order-status" method="POST">
                                <input type="hidden" name="orderId" value="<%= order._id %>">
                                <select name="status" onchange="this.form.submit()" class="border rounded p-1 text-sm bg-orange-50 font-bold text-orange-700">
                                    <option value="Pending" <%= order.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                                    <option value="Processing" <%= order.status === 'Processing' ? 'selected' : '' %>>Processing</option>
                                    <option value="Shipped" <%= order.status === 'Shipped' ? 'selected' : '' %>>Shipped</option>
                                    <option value="Delivered" <%= order.status === 'Delivered' ? 'selected' : '' %>>Mark as Done (Delivered)</option>
                                    <option value="Cancelled" <%= order.status === 'Cancelled' ? 'selected' : '' %>>Cancel Order</option>
                                </select>
                            </form>
                        </div>
                    </div>
                <% }) %>
                <% if(liveOrders.length === 0) { %><p class="text-gray-400 italic">No live orders right now.</p><% } %>
            </div>
        </section>

        <section>
            <h2 class="text-2xl font-black text-gray-400 mb-4 flex items-center">
                <span class="mr-2">✅</span> COMPLETED ORDERS
            </h2>
            <div class="bg-white rounded-xl shadow-inner overflow-hidden">
                <table class="w-full text-left">
                    <thead class="bg-gray-100 text-gray-500 text-sm">
                        <tr>
                            <th class="p-4">Customer</th>
                            <th>Total</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% doneOrders.forEach(order => { %>
                            <tr class="border-b opacity-60">
                                <td class="p-4 font-medium"><%= order.user ? order.user.username : 'Guest' %></td>
                                <td class="font-bold">$<%= order.totalAmount %></td>
                                <td>
                                    <span class="<%= order.status === 'Delivered' ? 'text-green-600' : 'text-red-500' %> font-bold uppercase text-xs">
                                        <%= order.status %>
                                    </span>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </section>
    </main>
</body>
</html>