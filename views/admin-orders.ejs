<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Manage Orders | Cafe Delight</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-serif { font-family: 'Playfair Display', serif; }
    </style>
</head>
<body class="bg-stone-50 text-stone-900 min-h-screen">
    <nav class="bg-stone-900 text-white px-10 py-6 flex justify-between items-center sticky top-0 z-50">
        <div class="flex items-center gap-12">
            <a href="/" class="text-xl font-serif font-bold tracking-tight">Cafe<span class="text-amber-500">Admin</span></a>
            <div class="flex gap-8 text-sm font-bold uppercase tracking-widest text-stone-400">
                <a href="/admin-dashboard" class="hover:text-white transition-colors">Inventory</a>
                <a href="/admin-orders" class="text-white border-b-2 border-amber-500 pb-1">Orders</a>
            </div>
        </div>
        <a href="/logout" class="text-xs font-bold uppercase tracking-widest bg-white/10 px-4 py-2 rounded-lg hover:bg-white/20 transition-colors">Sign Out</a>
    </nav>

    <main class="max-w-7xl mx-auto px-10 py-16 space-y-24">
        <section>
            <h2 class="font-serif text-4xl mb-10 flex items-center gap-4">
                Live <span class="italic text-amber-600">Operations</span>
                <span class="text-xs bg-amber-100 text-amber-600 px-3 py-1 rounded-full font-black tracking-widest"><%= liveOrders.length %> ACTIVE</span>
            </h2>
            
            <div class="grid gap-4">
                <% liveOrders.forEach(order => { %>
                    <div class="bg-white p-8 rounded-[2rem] shadow-xl shadow-stone-200/40 border border-stone-100 flex flex-col md:flex-row justify-between items-start md:items-center gap-8 group">
                        <div class="space-y-3">
                            <div class="flex items-center gap-4">
                                <p class="text-[10px] font-black text-stone-300 uppercase tracking-widest">Order ID #<%= order._id.toString().slice(-6) %></p>
                                <span class="text-[10px] bg-stone-50 px-2 py-1 rounded font-bold text-stone-500">
                                    <%= new Date(order.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                                </span>
                            </div>
                            <h4 class="font-bold text-xl text-stone-800"><%= order.user ? order.user.username : 'Guest Student' %></h4>
                            <div class="flex flex-wrap gap-2">
                                <% order.items.forEach((item, index) => { %> 
                                    <span class="bg-stone-50 text-stone-600 px-2 py-1 rounded text-xs border border-stone-100 font-medium italic">
                                        <%= item.name %> x<%= item.quantity %>
                                    </span>
                                <% }) %>
                            </div>
                        </div>
                        
                        <div class="flex items-center gap-12 w-full md:w-auto justify-between md:justify-end">
                            <div class="text-right leading-none">
                                <p class="text-[10px] text-stone-300 font-black uppercase tracking-widest mb-1">Revenue</p>
                                <p class="font-black text-3xl text-stone-900">₹<%= order.totalAmount %></p>
                            </div>
                            
                            <form action="/update-order-status" method="POST" class="flex gap-2">
                                <input type="hidden" name="orderId" value="<%= order._id %>">
                                <select name="status" onchange="this.form.submit()" 
                                    class="bg-stone-50 border-none rounded-xl px-4 py-3 font-bold text-sm focus:ring-2 focus:ring-amber-500 cursor-pointer appearance-none pr-10">
                                    <option value="Pending" <%= order.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                                    <option value="Processing" <%= order.status === 'Processing' ? 'selected' : '' %>>Preparing</option>
                                    <option value="Shipped" <%= order.status === 'Shipped' ? 'selected' : '' %>>Shipping</option>
                                    <option value="Delivered" <%= order.status === 'Delivered' ? 'selected' : '' %>>Delivered</option>
                                    <option value="Cancelled" <%= order.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                                </select>
                            </form>
                        </div>
                    </div>
                <% }) %>
                
                <% if(liveOrders.length === 0) { %>
                    <div class="bg-white border-2 border-dashed border-stone-200 rounded-[2rem] py-16 text-center">
                        <p class="text-stone-400 font-medium italic">No live orders right now. Relax! ☕</p>
                    </div>
                <% } %>
            </div>
        </section>

        <section>
            <h2 class="font-serif text-3xl mb-10 opacity-40">Order History</h2>
            <div class="bg-stone-200/30 rounded-[2.5rem] p-10 overflow-hidden">
                <table class="w-full text-left border-collapse">
                    <thead class="text-[10px] uppercase tracking-widest font-black text-stone-400">
                        <tr>
                            <th class="pb-6">Date</th>
                            <th class="pb-6">Customer</th>
                            <th class="pb-6">Items</th>
                            <th class="pb-6">Total</th>
                            <th class="pb-6 text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm font-medium">
                        <% doneOrders.forEach(order => { %>
                            <tr class="border-t border-stone-200/50 hover:bg-white/40 transition-colors">
                                <td class="py-5 text-stone-400">
                                    <%= new Date(order.createdAt).toLocaleDateString() %>
                                </td>
                                <td class="py-5 font-bold text-stone-900">
                                    <%= order.user ? order.user.username : 'Guest' %>
                                </td>
                                <td class="py-5 text-stone-400 italic truncate max-w-xs">
                                    <%= order.items.map(i => `${i.name} (${i.quantity})`).join(', ') %>
                                </td>
                                <td class="py-5 font-black text-stone-900">₹<%= order.totalAmount %></td>
                                <td class="py-5 text-center">
                                    <span class="px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest
                                        <%= order.status === 'Delivered' ? 'bg-emerald-50 text-emerald-600' : 'bg-red-50 text-red-500' %>">
                                        <%= order.status %>
                                    </span>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
                <% if(doneOrders.length === 0) { %>
                    <div class="py-12 text-center text-stone-400 italic">No completed history available.</div>
                <% } %>
            </div>
        </section>
    </main>
</body>
</html>