<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Menu Management</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
    <nav class="bg-blue-600 p-4 text-white flex justify-between items-center shadow-lg">
        <h1 class="text-xl font-bold">Cafe Admin: Menu</h1>
        <div class="space-x-4">
            <a href="/admin-orders" class="hover:underline font-bold">View Orders 🛒</a>
            <a href="/logout" class="bg-red-500 px-3 py-1 rounded">Logout</a>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto p-6 space-y-8">
        <section class="bg-white p-6 rounded-xl shadow-md">
            <h2 class="text-2xl font-bold mb-4 text-gray-800">Add New Product</h2>
            <form action="/add-product" method="POST" enctype="multipart/form-data" class="grid grid-cols-2 gap-4">
                <input type="text" name="name" placeholder="Product Name" class="border p-2 rounded" required>
                <input type="text" name="category" placeholder="Category" class="border p-2 rounded" required>
                <input type="number" name="price" placeholder="Price" class="border p-2 rounded" required>
                <input type="number" name="stock" placeholder="Stock Quantity" class="border p-2 rounded" required>
                <textarea name="description" placeholder="Description" class="border p-2 rounded col-span-2"></textarea>
                <input type="file" name="image" class="col-span-2 border p-2 rounded">
                <button type="submit" class="col-span-2 bg-blue-600 text-white font-bold py-2 rounded hover:bg-blue-700">Add to Menu</button>
            </form>
        </section>

        <section class="bg-white p-6 rounded-xl shadow-md">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-2xl font-bold text-gray-800">Existing Menu Items</h2>
                <div class="text-sm text-gray-500 font-medium">Page <%= current %> of <%= pages %></div>
            </div>
            
            <table class="w-full text-left">
                <thead>
                    <tr class="border-b text-gray-600 uppercase text-xs tracking-wider">
                        <th class="py-3">Image</th>
                        <th>Name</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% products.forEach(product => { %>
                        <tr class="border-b hover:bg-gray-50 transition-colors <%= !product.isActive ? 'opacity-60 bg-gray-50' : '' %>">
                            <td class="py-3">
                                <img src="<%= product.image %>" class="w-12 h-12 object-cover rounded shadow-sm">
                            </td>
                            <td class="font-bold text-gray-700">
                                <%= product.name %>
                                <br>
                                <span class="text-[10px] text-blue-500 uppercase"><%= product.category %></span>
                            </td>
                            <td class="text-green-600 font-bold">$<%= product.price %></td>
                            <td class="text-gray-600 font-medium"><%= product.stock %></td>
                            
                            <td>
                                <% if (product.isActive) { %>
                                    <span class="px-2 py-1 rounded-full bg-green-100 text-green-700 text-xs font-bold">Active</span>
                                <% } else { %>
                                    <span class="px-2 py-1 rounded-full bg-red-100 text-red-700 text-xs font-bold">Inactive</span>
                                <% } %>
                            </td>

                            <td class="flex justify-center items-center space-x-4 py-4">
                                <form action="/toggle-product/<%= product._id %>" method="POST">
                                    <button type="submit" class="text-xs font-bold px-3 py-1.5 rounded transition <%= product.isActive ? 'bg-gray-100 text-gray-600 hover:bg-gray-200' : 'bg-green-600 text-white hover:bg-green-700' %>">
                                        <%= product.isActive ? 'Deactivate' : 'Activate' %>
                                    </button>
                                </form>

                                <a href="/delete-product/<%= product._id %>" 
                                   class="text-red-500 text-xs font-bold hover:underline" 
                                   onclick="return confirm('Are you sure you want to delete this product permanentely?')">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>

            <% if (pages > 1) { %>
                <div class="mt-8 flex justify-center items-center space-x-2">
                    <% if (current > 1) { %>
                        <a href="/admin-dashboard?page=<%= current - 1 %>" class="px-3 py-1 border rounded hover:bg-gray-100">Prev</a>
                    <% } %>
                    
                    <% for(let i=1; i <= pages; i++) { %>
                        <a href="/admin-dashboard?page=<%= i %>" class="px-3 py-1 border rounded <%= current == i ? 'bg-blue-600 text-white' : 'hover:bg-gray-100' %>">
                            <%= i %>
                        </a>
                    <% } %>

                    <% if (current < pages) { %>
                        <a href="/admin-dashboard?page=<%= current + 1 %>" class="px-3 py-1 border rounded hover:bg-gray-100">Next</a>
                    <% } %>
                </div>
            <% } %>
        </section>
    </main>
</body>
</html>