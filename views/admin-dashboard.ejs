<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | Cafe Delight</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-serif { font-family: 'Playfair Display', serif; }
    </style>
</head>
<body class="bg-stone-50 text-stone-900 min-h-screen">
    <nav class="bg-stone-900 text-white px-10 py-6 flex justify-between items-center sticky top-0 z-50">
        <div class="flex items-center gap-12">
            <a href="/" class="text-xl font-serif font-bold tracking-tight">Cafe<span class="text-amber-500">Admin</span></a>
            <div class="flex gap-8 text-sm font-bold uppercase tracking-widest text-stone-400">
                <a href="/admin-dashboard" class="text-white border-b-2 border-amber-500 pb-1">Inventory</a>
                <a href="/admin-orders" class="hover:text-white transition-colors">Orders</a>
            </div>
        </div>
        <a href="/logout" class="text-xs font-bold uppercase tracking-widest bg-white/10 px-4 py-2 rounded-lg hover:bg-white/20">Sign Out</a>
    </nav>

    <main class="max-w-7xl mx-auto px-10 py-16">
        <div class="flex justify-between items-end mb-16">
            <div>
                <h1 class="font-serif text-5xl mb-2">Inventory <span class="text-amber-600">Control</span></h1>
                <p class="text-stone-400">Manage your menu offerings and stock levels</p>
            </div>
            <a href="/add-product" class="bg-amber-600 text-white px-8 py-4 rounded-2xl font-bold hover:bg-amber-700 transition-all shadow-xl shadow-amber-900/20 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                New Product
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% products.forEach(product => { %>
                <div class="bg-white rounded-[2.5rem] overflow-hidden shadow-xl shadow-stone-200/50 border border-stone-100 flex flex-col">
                    <div class="h-48 relative overflow-hidden">
                        <img src="<%= product.image %>" class="w-full h-full object-cover <%= !product.isActive ? 'grayscale opacity-50' : '' %>" alt="">
                        <div class="absolute top-4 right-4 flex gap-2">
                             <a href="/toggle-status/<%= product._id %>" class="p-2 bg-white/90 backdrop-blur rounded-xl shadow-sm hover:text-amber-600 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                             </a>
                             <a href="/delete-product/<%= product._id %>" onclick="return confirm('Archive this item?')" class="p-2 bg-white/90 backdrop-blur rounded-xl shadow-sm hover:text-red-600 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                             </a>
                        </div>
                    </div>
                    <div class="p-8 flex-grow">
                        <div class="flex justify-between items-start mb-4">
                            <h3 class="text-xl font-bold"><%= product.name %></h3>
                            <span class="text-[10px] font-black uppercase tracking-widest text-amber-600 bg-amber-50 px-2 py-1 rounded"><%= product.category %></span>
                        </div>
                        <div class="flex justify-between items-center text-sm">
                            <span class="text-stone-400">Stock: <b class="text-stone-900"><%= product.stock %></b></span>
                            <span class="font-black text-lg">₹<%= product.price %></span>
                        </div>
                    </div>
                    <div class="p-4 bg-stone-50 border-t border-stone-100 flex gap-2">
                        <a href="/edit-product/<%= product._id %>" class="flex-grow text-center py-3 bg-stone-900 text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-stone-800 transition-colors">Edit Details</a>
                    </div>
                </div>
            <% }) %>
        </div>

        <!-- Pagination -->
        <% if (pages > 1) { %>
            <div class="mt-16 flex justify-center gap-3">
                <% for (let i = 1; i <= pages; i++) { %>
                    <a href="/admin-dashboard?page=<%= i %>" 
                       class="w-12 h-12 flex items-center justify-center rounded-2xl font-black transition-all <%= current == i ? 'bg-amber-600 text-white shadow-lg' : 'bg-white text-stone-400 hover:bg-stone-100 border border-stone-200' %>">
                        <%= i %>
                    </a>
                <% } %>
            </div>
        <% } %>
    </main>
</body>
</html>