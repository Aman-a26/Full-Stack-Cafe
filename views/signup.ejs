<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cafe Food - Sign Up</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-[#f093fb] to-[#f5576c] min-h-screen flex justify-center items-center font-sans p-5">

    <div class="bg-white p-10 rounded-xl shadow-2xl w-full max-w-[450px]">
        <div class="text-center mb-8">
            <h1 class="text-[#333] text-3xl font-bold mb-2 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-9 h-9 mr-2 text-[#f5576c]">
                    <path d="M10.5 1.875a.75.75 0 0 0-1.5 0v8.25c0 .414.336.75.75.75h6.375a3.75 3.75 0 0 1 0 7.5H5.25a.75.75 0 0 0 0 1.5h9.375a5.25 5.25 0 0 0 0-10.5H10.5V1.875Z" />
                </svg>
                <span>Cafe Food</span>
            </h1>
            <p class="text-gray-500 text-sm">Create Your Account</p>
        </div>

        <% if (error) { %>
            <div class="bg-red-100 border border-red-200 text-red-800 p-3 rounded-md mb-5 text-sm text-center">
                <%= error %>
            </div>
        <% } %>

        <form id="signupForm" method="POST" action="/signup" class="space-y-5">
            <div>
                <label for="username" class="block mb-1 text-gray-800 font-medium">Full Name</label>
                <input type="text" id="username" name="username" required placeholder="John Doe"
                       class="w-full p-3 border border-gray-300 rounded-md text-sm outline-none focus:border-[#f5576c] focus:ring-2 focus:ring-[#f5576c]/20 transition-all">
            </div>

            <div>
                <label for="email" class="block mb-1 text-gray-800 font-medium">Email Address</label>
                <input type="email" id="email" name="email" required placeholder="your@email.com"
                       class="w-full p-3 border border-gray-300 rounded-md text-sm outline-none focus:border-[#f5576c] focus:ring-2 focus:ring-[#f5576c]/20 transition-all">
            </div>

            <div>
                <label for="collegeId" class="block mb-1 text-gray-800 font-medium">College ID</label>
                <input type="text" id="collegeId" name="collegeId" required placeholder="Your college ID number"
                       class="w-full p-3 border border-gray-300 rounded-md text-sm outline-none focus:border-[#f5576c] focus:ring-2 focus:ring-[#f5576c]/20 transition-all">
            </div>

            <div>
                <label for="password" class="block mb-1 text-gray-800 font-medium">Password</label>
                <input type="password" id="password" name="password" required minlength="6" placeholder="At least 6 characters"
                       class="w-full p-3 border border-gray-300 rounded-md text-sm outline-none focus:border-[#f5576c] focus:ring-2 focus:ring-[#f5576c]/20 transition-all">
            </div>

            <div>
                <label for="confirmPassword" class="block mb-1 text-gray-800 font-medium">Confirm Password</label>
                <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="Re-enter password"
                       class="w-full p-3 border border-gray-300 rounded-md text-sm outline-none focus:border-[#f5576c] focus:ring-2 focus:ring-[#f5576c]/20 transition-all">
            </div>

            <input type="hidden" name="role" value="student">

            <button type="submit" 
                    class="w-full p-3 bg-gradient-to-r from-[#f093fb] to-[#f5576c] text-white rounded-md font-semibold text-lg hover:-translate-y-0.5 transition-transform active:translate-y-0 shadow-md">
                Create Account
            </button>
        </form>

        <div class="text-center mt-6 text-gray-500 text-sm">
            Already have an account? <a href="/login" class="text-[#f5576c] font-bold hover:underline">Login Here</a>
        </div>
    </div>

    <script>
        // Simple frontend check to ensure passwords match
        const form = document.getElementById('signupForm');
        form.addEventListener('submit', (e) => {
            const pass = document.getElementById('password').value;
            const confirm = document.getElementById('confirmPassword').value;
            if (pass !== confirm) {
                e.preventDefault();
                alert("Passwords do not match!");
            }
        });
    </script>
</body>
</html>