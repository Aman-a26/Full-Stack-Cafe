<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account | Cafe Delight</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: radial-gradient(circle at bottom left, #fffbeb, #fafaf9); }
        .font-serif { font-family: 'Playfair Display', serif; }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-center p-6">
    <div class="mb-8 text-center">
        <a href="/" class="text-3xl font-serif font-bold text-amber-900 tracking-tight flex items-center justify-center gap-2">
            <span class="bg-amber-100 p-2 rounded-2xl text-amber-600 italic">C</span> Cafe Delight
        </a>
    </div>

    <div class="bg-white/80 backdrop-blur-xl p-10 rounded-[2.5rem] shadow-2xl shadow-amber-900/10 w-full max-w-lg border border-white/50">
        <div class="text-center mb-8">
            <h2 class="font-serif text-3xl text-stone-900 mb-2">Join the Club</h2>
            <p class="text-stone-400 text-sm">Create your student account for artisanal treats</p>
        </div>

        <% if (error) { %>
            <div class="bg-red-50 text-red-600 p-4 rounded-2xl mb-6 text-xs font-semibold text-center border border-red-100">
                <i class="fas fa-exclamation-circle mr-1"></i> <%= error %>
            </div>
        <% } %>

        <form id="signupForm" method="POST" action="/signup" class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="md:col-span-2">
                <label class="block text-[10px] font-bold text-stone-400 uppercase tracking-widest mb-2 ml-1">Full Name</label>
                <input type="text" id="username" name="username" required placeholder="John Doe"
                       class="w-full px-5 py-4 bg-stone-50 rounded-2xl border-none focus:ring-2 focus:ring-amber-500 transition-all text-stone-700">
            </div>

            <div>
                <label class="block text-[10px] font-bold text-stone-400 uppercase tracking-widest mb-2 ml-1">Email Address</label>
                <input type="email" id="email" name="email" required placeholder="john@college.edu"
                       class="w-full px-5 py-4 bg-stone-50 rounded-2xl border-none focus:ring-2 focus:ring-amber-500 transition-all text-stone-700">
            </div>

            <div>
                <label class="block text-[10px] font-bold text-stone-400 uppercase tracking-widest mb-2 ml-1">College ID</label>
                <input type="text" id="collegeId" name="collegeId" required placeholder="ID-12345"
                       class="w-full px-5 py-4 bg-stone-50 rounded-2xl border-none focus:ring-2 focus:ring-amber-500 transition-all text-stone-700">
            </div>

            <div>
                <label class="block text-[10px] font-bold text-stone-400 uppercase tracking-widest mb-2 ml-1">Password</label>
                <input type="password" id="password" name="password" required minlength="6" placeholder="At least 6 characters"
                       class="w-full px-5 py-4 bg-stone-50 rounded-2xl border-none focus:ring-2 focus:ring-amber-500 transition-all text-stone-700">
            </div>

            <div>
                <label class="block text-[10px] font-bold text-stone-400 uppercase tracking-widest mb-2 ml-1">Confirm Password</label>
                <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="••••••••"
                       class="w-full px-5 py-4 bg-stone-50 rounded-2xl border-none focus:ring-2 focus:ring-amber-500 transition-all text-stone-700">
            </div>

            <input type="hidden" name="role" value="student">

            <button type="submit" class="md:col-span-2 py-5 bg-stone-900 text-white rounded-2xl font-bold text-lg hover:bg-amber-800 transition-all shadow-xl shadow-stone-900/20 active:scale-95 mt-4">
                Create Account
            </button>
        </form>

        <div class="text-center mt-8 text-stone-500 text-sm">
            Already a member? <a href="/login" class="text-amber-600 font-bold hover:underline underline-offset-4">Sign In</a>
        </div>
    </div>

    <footer class="mt-12 text-stone-400 text-[10px] uppercase tracking-[0.2em]">
        &copy; 2026 Cafe Delight System
    </footer>

    <script>
        // Simple frontend check to ensure passwords match
        const form = document.getElementById('signupForm');
        form.addEventListener('submit', (e) => {
            const pass = document.getElementById('password').value;
            const confirm = document.getElementById('confirmPassword').value;
            if (pass !== confirm) {
                e.preventDefault();
                alert("Passwords do not match!");
            }
        });
    </script>
</body>
</html>