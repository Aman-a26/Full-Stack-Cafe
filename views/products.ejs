<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Our Menu | Cafe Delight</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-serif { font-family: 'Playfair Display', serif; }
        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(0,0,0,0.05); }
        @keyframes slideIn { from { transform: translateX(400px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        .animate-slideIn { animation: slideIn 0.3s ease-in; }
    </style>
</head>
<body class="bg-stone-50 text-stone-900">
    
    <div id="message" class="fixed top-5 right-5 px-6 py-4 rounded shadow-lg text-white font-semibold z-[1000] hidden animate-slideIn"></div>

    <nav class="sticky top-0 z-50 glass px-6 py-5 flex justify-between items-center">
        <a href="/" class="text-2xl font-serif font-bold text-amber-900 tracking-tight flex items-center gap-2">
            Cafe<span class="text-amber-600">Delight</span>
        </a>

        <div class="flex gap-8 items-center">
            <a href="/" class="font-semibold text-stone-600 hover:text-amber-600 transition-all">Home</a>
            <a href="/products" class="font-black text-amber-600 border-b-2 border-amber-600 pb-1">Menu</a>
            <% if (user) { %>
                <a href="/user-dashboard" class="font-semibold text-stone-600 hover:text-amber-600">Dashboard</a>
                <a href="/cart" class="flex items-center gap-2 font-semibold text-stone-600 hover:text-amber-600 transition-all">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                    Cart
                </a>
                <a href="/logout" class="text-stone-400 hover:text-red-500 transition-colors"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg></a>
            <% } else { %>
                <a href="/login" class="bg-stone-900 text-white px-6 py-2 rounded-full font-bold text-sm hover:bg-amber-800 transition-all shadow-lg shadow-stone-900/10">Login</a>
                <a href="/signup" class="font-bold text-stone-600 hover:text-stone-900">Sign Up</a>
            <% } %>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-6 py-24">
        <div class="text-center mb-20 max-w-2xl mx-auto">
            <span class="text-[10px] font-black uppercase tracking-[0.5em] text-amber-600 mb-4 block">Handcrafted Selection</span>
            <h2 class="font-serif text-5xl md:text-7xl text-stone-900 mb-6 tracking-tight">Our <span class="italic text-amber-600 font-normal">Menu</span></h2>
            <p class="text-stone-400 text-lg leading-relaxed">Every recipe is a journey of flavor, crafted with precision by our artisanal chefs.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-10">
            <% products.forEach(product => { %>
                <div class="bg-white rounded-[2.5rem] overflow-hidden shadow-xl shadow-stone-200/50 hover:-translate-y-3 transition-all duration-500 border border-stone-100 group flex flex-col">
                    <div class="relative h-56 overflow-hidden">
                        <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                        <div class="absolute bottom-4 right-4 bg-white/90 backdrop-blur px-4 py-1.5 rounded-full text-lg font-black text-amber-800 border border-white">
                            ₹<%= product.price %>
                        </div>
                    </div>

                    <div class="p-8 flex-grow flex flex-col">
                        <span class="text-[10px] uppercase tracking-widest text-stone-300 font-black mb-2 block"><%= product.category %></span>
                        <h3 class="font-serif text-2xl text-stone-900 mb-3 leading-tight"><%= product.name %></h3>
                        <p class="text-stone-400 text-sm mb-8 line-clamp-2 leading-relaxed flex-grow">
                            <%= product.description %>
                        </p>
                        
                        <div class="mt-auto">
                            <div class="flex items-center gap-4 mb-6">
                                <label for="qty-<%= product.id %>" class="text-[10px] font-black text-stone-300 uppercase tracking-widest">Quantity</label>
                                <input type="number" id="qty-<%= product.id %>" min="1" value="1" 
                                       class="w-16 bg-stone-50 border-none rounded-xl p-2 text-center text-sm font-bold focus:ring-2 focus:ring-amber-500 outline-none transition-all">
                            </div>
                            
                            <button class="w-full bg-stone-900 text-white py-4 rounded-2xl font-bold hover:bg-amber-800 active:scale-95 transition-all shadow-xl shadow-stone-900/10"
                                    data-product-id="<%= product.id %>" 
                                    onclick="addToCart(this.getAttribute('data-product-id'))">
                                Add to Cart
                            </button>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </main>

    <footer class="py-20 text-center border-t border-stone-100">
        <p class="text-stone-300 text-xs uppercase tracking-[0.4em] mb-6">&copy; 2026 Cafe Delight Artisanal Food</p>
        <div class="flex justify-center gap-8 text-stone-500 font-medium text-sm">
            <a href="#" class="hover:text-amber-600 transition-colors">Privacy</a>
            <a href="#" class="hover:text-amber-600 transition-colors">Contact</a>
            <a href="#" class="hover:text-amber-600 transition-colors">Instagram</a>
        </div>
    </footer>

    <script>
        function addToCart(productId) {
            const quantityInput = document.getElementById(`qty-${productId}`);
            const quantity = quantityInput.value;
            
            fetch('/add-to-cart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId, quantity })
            })
            .then(res => res.json())
            .then(data => {
                showMessage(data.message, data.success ? 'success' : 'error');
                if (data.success) {
                    quantityInput.value = 1;
                }
            })
            .catch(err => showMessage('Error adding to cart', 'error'));
        }

        function showMessage(msg, type) {
            const msgDiv = document.getElementById('message');
            msgDiv.textContent = msg;
            
            // Reset classes
            msgDiv.className = 'fixed top-5 right-5 px-6 py-4 rounded shadow-lg text-white font-semibold z-[1000] animate-slideIn block';
            
            if (type === 'success') {
                msgDiv.classList.add('bg-green-500');
            } else {
                msgDiv.classList.add('bg-red-500');
            }
            
            setTimeout(() => {
                msgDiv.classList.add('hidden');
                msgDiv.classList.remove('block');
            }, 3000);
        }
    </script>
</body>
</html>