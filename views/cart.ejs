<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Cart | Cafe Food</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">

    <nav class="bg-white shadow-sm p-4 mb-8">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <a href="/user-dashboard" class="text-orange-500 font-bold">← Back to Menu</a>
            <h1 class="text-xl font-black text-gray-800 uppercase">Cafe Food</h1>
            <div class="w-20"></div> </div>
    </nav>

    <main class="max-w-3xl mx-auto px-4">
        <div class="bg-white rounded-3xl shadow-sm p-8">
            <h2 class="text-3xl font-black text-gray-900 mb-8">Your Cart</h2>

            <% if (cart.length === 0) { %>
                <div class="text-center py-10">
                    <p class="text-gray-400">Your cart is empty.</p>
                    <a href="/user-dashboard" class="text-orange-500 font-bold mt-4 inline-block">Browse Food</a>
                </div>
            <% } else { %>
                <div class="space-y-6">
                    <% cart.forEach(item => { %>
                        <div class="flex justify-between items-center border-b pb-6 last:border-0">
                            <div>
                                <h4 class="text-lg font-bold text-gray-800"><%= item.name %></h4>
                                <p class="text-gray-400">$<%= item.price %> x <%= item.quantity %></p>
                                
                                <div class="flex items-center gap-4 mt-2">
                                    <a href="/cart/dec/<%= item.id %>" class="bg-gray-100 px-3 py-1 rounded-lg font-bold">-</a>
                                    <span class="font-bold"><%= item.quantity %></span>
                                    <a href="/cart/inc/<%= item.id %>" class="bg-gray-100 px-3 py-1 rounded-lg font-bold">+</a>
                                    <a href="/cart/rem/<%= item.id %>" class="text-red-400 text-xs ml-4 uppercase font-bold">Remove</a>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="text-xl font-black text-gray-900">$<%= (item.price * item.quantity).toFixed(2) %></p>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <div class="mt-10 p-6 bg-orange-50 rounded-2xl border border-orange-100 flex justify-between items-center">
                    <span class="text-gray-600 font-bold uppercase tracking-widest text-sm">Total Amount</span>
                    <span class="text-3xl font-black text-orange-600">$<%= total.toFixed(2) %></span>
                </div>

                <div class="mt-8">
                    <% if (user) { %>
                        <form action="/checkout" method="POST">
                            <button type="submit" class="w-full bg-green-500 text-white py-4 rounded-2xl font-black text-xl hover:bg-green-600 transition shadow-lg">
                                CONFIRM ORDER
                            </button>
                        </form>
                    <% } else { %>
                        <div class="space-y-4">
                            <p class="text-center text-gray-400 text-sm italic font-medium">Please login to complete your transaction</p>
                            <a href="/login" class="block w-full text-center bg-blue-600 text-white py-4 rounded-2xl font-black text-xl hover:bg-blue-700 transition shadow-lg">
                                LOGIN TO CHECKOUT
                            </a>
                        </div>
                    <% } %>
                </div>
            <% } %>
        </div>
    </main>

</body>
</html>