<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - Cafe Food</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-[#f093fb] to-[#f5576c] min-h-screen flex justify-center items-center font-sans p-5">

    <div class="bg-white p-10 rounded-xl shadow-2xl w-full max-w-[450px]">
        <div class="text-center mb-8">
            <h1 class="text-[#333] text-3xl font-bold mb-2">Reset Password</h1>
            <p class="text-gray-500 text-sm">Enter your email to receive a reset link.</p>
        </div>

        <% if (message) { %>
            <div class="bg-green-100 border border-green-200 text-green-800 p-3 rounded-md mb-5 text-sm">
                <%= message %>
            </div>
        <% } %>
        <% if (error) { %>
            <div class="bg-red-100 border border-red-200 text-red-800 p-3 rounded-md mb-5 text-sm">
                <%= error %>
            </div>
        <% } %>

        <form method="POST" action="/forgot-password" class="space-y-5">
            <div>
                <label for="email" class="block mb-1 text-gray-800 font-medium">Email Address</label>
                <input type="email" id="email" name="email" required placeholder="your@email.com"
                       class="w-full p-3 border border-gray-300 rounded-md text-sm outline-none focus:border-[#f5576c] focus:ring-2 focus:ring-[#f5576c]/20 transition-all">
            </div>

            <button type="submit" class="w-full p-3 bg-gradient-to-r from-[#f093fb] to-[#f5576c] text-white rounded-md font-semibold text-lg hover:-translate-y-0.5 transition-transform active:translate-y-0 shadow-md">
                Send Reset Link
            </button>
        </form>
    </div>

</body>
</html>